# Deny when an instance update results in a higher or equal cost.
# Both instance types must be in the pricing table; if either is unknown
# the rule is silent (other policies handle unknown types).

deny contains msg if {
    resource := input.resource_changes[_]
    resource.type == "aws_instance"
    resource.change.actions == ["update"]

    old_type := resource.change.before.instance_type
    new_type := resource.change.after.instance_type
    old_type != new_type

    old_cost := instance_cost[old_type]
    new_cost := instance_cost[new_type]

    new_cost >= old_cost

    msg := sprintf(
        "aws_instance.%s: DOWNSIZE from %s ($%.4f/hr) to %s ($%.4f/hr) does not reduce cost — new type must be strictly cheaper",
        [resource.name, old_type, old_cost, new_type, new_cost],
    )
}
