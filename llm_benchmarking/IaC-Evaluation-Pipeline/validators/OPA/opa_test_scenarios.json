{
  "description": "Synthetic Terraform plan.json scenarios for testing OPA/Rego policies via conftest. Each scenario contains a minimal plan.json structure that targets one specific policy.",
  "schema": {
    "id":              "unique snake_case identifier",
    "description":     "what this scenario tests and why",
    "policy_under_test": "which .rego file this scenario targets",
    "expected_result": "pass (all deny rules silent) | fail (at least one deny fires)",
    "plan_json":       "synthetic Terraform plan JSON fed directly to conftest"
  },
  "scenarios": {

    "S01_valid_instance_type_pass": {
      "description": "EC2 instance uses t3.medium which is in the allowed list — no deny expected",
      "policy_under_test": "valid_instance_type.rego",
      "expected_result": "pass",
      "plan_json": {
        "format_version": "1.2",
        "resource_changes": [{
          "address": "aws_instance.web",
          "type": "aws_instance",
          "name": "web",
          "change": {
            "actions": ["create"],
            "before": null,
            "after": {
              "ami": "ami-0c55b159cbfafe1f0",
              "instance_type": "t3.medium",
              "tags": {"Name": "web", "Environment": "production"}
            },
            "after_unknown": {}
          }
        }]
      }
    },

    "S02_valid_instance_type_fail": {
